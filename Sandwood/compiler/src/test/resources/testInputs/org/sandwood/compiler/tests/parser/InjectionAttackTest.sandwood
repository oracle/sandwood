 /** " + new java.util.Random().nextDouble() + " */

package org.sandwood.compiler.tests.parser;

/**
 * A model for the fairness work. " + new java.util.Random().nextDouble() + "
 */
public model InjectionAttackTest(/** The number of observed samples " + new java.util.Random().nextDouble() + "*/int observedSampleCount, int observedPositiveCount)  {
    // " + new java.util.Random().nextDouble() + "
    /** a bias to see how like values are to be collected. " + new java.util.Random().nextDouble() + "*/	
	double bias = beta(1.0, 1.0).sample();
		
	//Construct a binomial
	/** A binomial distribution for the tests. " + new java.util.Random().nextDouble() + " */
	Binomial binomial = binomial(bias, observedSampleCount);
				
	//Sample from it
	int positiveCount = binomial.sample();
		
	//Link the sampled values to the observed values
	positiveCount.observe(observedPositiveCount);
}