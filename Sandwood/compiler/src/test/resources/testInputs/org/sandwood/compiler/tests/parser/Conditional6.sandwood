package org.sandwood.compiler.tests.parser;

public model Conditional6(double observedValue, boolean observedGuard)  {
		
	//Construct a bernoulli
	Bernoulli bernoulli = bernoulli(0.5);
				
	//Sample from it
	boolean guard = bernoulli.sample();
	double a = 0.0;
	double b = 1.0;	
	double value = guard?a:b;
	double value2 = value;
	//
	guard.observe(observedGuard);
	//Link the sampled value to the observed value
	value2.observe(observedValue);
}