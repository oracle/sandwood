package alarms;

/*
 * person(john).
 * person(mary).
 * 
 * 0.7::burglary.
 * 0.2::earthquake.
 * 
 * 0.9::alarm :- burglary, earthquake.
 * 0.8::alarm :- burglary, \+earthquake.
 * 0.1::alarm :- \+burglary, earthquake.
 * 
 * 0.8::calls(X) :- alarm, person(X).
 * 0.1::calls(X) :- \+alarm, person(X).
 * 
 * evidence(calls(john),true).
 * evidence(calls(mary),true).
 * 
 * query(burglary).
 * query(earthquake).
 */

public model Alarms3() {
	double p_burglary = 0.7;
	double p_earthquake = 0.2;
	
	boolean earthquake = bernoulli(p_earthquake).sample();
	boolean burglary = bernoulli(p_burglary).sample();
	
	boolean alarm;
	if(burglary) {
		if(earthquake) {
			alarm = bernoulli(0.9).sample();
		} else {
			alarm = bernoulli(0.8).sample();
		}
	} else {
		if(earthquake) {
			alarm = bernoulli(0.1).sample();
		} else {
			alarm = false;
		}
	}
	
	boolean johnCalls;
	boolean maryCalls;
	if(alarm) {
		Bernoulli alarmCall = bernoulli(0.8);
		johnCalls = alarmCall.sample();
		maryCalls = alarmCall.sample();
	} else {
		Bernoulli noAlarmCall = bernoulli(0.1);
		johnCalls = noAlarmCall.sample();
		maryCalls = noAlarmCall.sample();
	}
	
	johnCalls.observe(true);
	maryCalls.observe(true);
}