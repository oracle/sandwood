package org.sandwood.compiler.tests.parser;

public model DistributionTest7(double observedData ) {

    double[] bias = {0.2, 0.3, 0.5};
    double[] prob = {0.2, 0.4, 0.4};

    int cat = categorical(prob).sampleDistribution();
    int result;
    if(cat != 1) {
    	result = binomial(bias[cat], 10).sample();
    } else {
    	result = 5;
    }
    

    double data = gaussian(result, (double) cat).sample();

    data.observe(observedData);

    }