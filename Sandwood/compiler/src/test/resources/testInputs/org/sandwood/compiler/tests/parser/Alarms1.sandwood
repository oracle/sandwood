package alarms;

/*
 * 0.7::burglary.
 * 0.2::earthquake.
 * 0.9::p_alarm1.
 * 0.8::p_alarm2.
 * 0.1::p_alarm3.
 * 
 * alarm :- burglary, earthquake, p_alarm1.
 * alarm :- burglary, \+earthquake, p_alarm2.
 * alarm :- \+burglary, earthquake, p_alarm3.
 * 
 * evidence(alarm,true).
 */

public model Alarms1() {
	double p_burglary = 0.7;
	double p_earthquake = 0.2;
	double p_alarm1 = 0.9;
	double p_alarm2 = 0.8;
	double p_alarm3 = 0.1;
	
	boolean earthquake = bernoulli(p_earthquake).sample();
	boolean burglary = bernoulli(p_burglary).sample();
	
	boolean alarm;
	if(burglary) {
		if(earthquake) {
			alarm = bernoulli(p_alarm1).sample();
		} else {
			alarm = bernoulli(p_alarm2).sample();
		}
	} else {
		if(earthquake) {
			alarm = bernoulli(p_alarm3).sample();
		} else {
			alarm = false;
		}
	}
	
	alarm.observe(true);
}