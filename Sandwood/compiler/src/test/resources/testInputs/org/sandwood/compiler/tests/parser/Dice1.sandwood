package dice;

/*
 * % annotated disjunctions
 * 1/6::one1; 1/6::two1; 1/6::three1; 1/6::four1; 1/6::five1; 1/6::six1.
 * 0.15::one2; 0.15::two2; 0.15::three2; 0.15::four2; 0.15::five2; 0.25::six2.
 * 
 * % Rules:
 * twoSix :- six1, six2.
 * 
 * someSix :- six1.
 * someSix :- six2.
 * 
 * % Queries:
 * query(six1).
 * query(six2).
 * query(twoSix).
 * query(someSix).
 */

public model Dice1() {
	double[] p_die1 = new double[6] <~ 1/6;
	double[] p_die2 = {0.15, 0.15, 0.15, 0.15, 0.15, 0.25};
	
	int die1 = categorical(p_die1).sample() + 1;
	int die2 = categorical(p_die2).sample() + 1;
	
	boolean twoSix = (die1 == 6) && (die2 == 6);
	boolean someSix = (die1 == 6) || (die2 == 6);
}