package com.oracle.labs.east.knownErrors;

public model RedFlags(boolean[][] obsA, boolean[] obsX, boolean[][] obsFlags) {
    int N = obsX.length; //number of obs in the sample
    int nAlarms = 3;    //obsE[0].length;
    int nFlags = 2;    //obsFlags[0].length -- will it work if some of the flags are not observed?

    // e.g. the structure is the following:
    // rf1 -> a1; rf2 -> a2, a3; //extend later to make alarms depend on multiple red flags

    double p = beta(1,100).sample(); // percentage of criminals in the population

    boolean[] x = new boolean[N];
    boolean[] xDisc = new boolean[N];  // observe those and not true type
    boolean[][] a = new boolean[N][nAlarms];

    boolean[][] flags = new boolean[N][nFlags];
    boolean[][] flagsDisc = new boolean[N][nFlags];  // observe those, and not actual flags

    // draw red flags conditional on the type
    // is there an elegant way to do CPT in Sandwood??
    double rf1_type_TruePositive = beta (9,1).sample();
    double rf1_type_FalsePositive =beta(1,9).sample();

    double rf2_type_TruePositive = beta(6,1).sample();  //criminal is less likely to trigger rf2 than rf1
    double rf2_type_FalsePositive = beta(1,1).sample(); //citizen is more likely to trigger rf2 than rf1. But still, less likely to trigger rf2 than a criminal

    double a1_rf1_TruePositive = beta(4,1).sample();  //if red flag is present, alarm will sound in 80% of cases?
    double a1_rf1_FalsePositive = beta(1,10).sample(); //if red flag is not present, alarm can go off with small probability

    double a2_rf1_TruePositive = beta(1,1).sample();  //if red flag is present, alarm will sound in 50% of cases?
    double a2_rf1_FalsePositive = beta(1,3).sample(); //if red flag is not present, alarm can go off with 25% probability

    double a3_rf2_TruePositive = beta(4,1).sample();  //if red flag is present, alarm will sound in 80% of cases?
    double a3_rf2_FalsePositive = beta(1,10).sample(); //if red flag is not present, alarm can go off with small probability


    for(int t : [0..N)) {
        // draw an x
        x[t] = bernoulli(p).sample();
        //depending on the result of x, draw values of red flags
        flags[t][0] = bernoulli(x[t]? rf1_type_TruePositive : rf1_type_FalsePositive).sample();
        flags[t][1] = bernoulli(x[t]? rf2_type_TruePositive : rf2_type_FalsePositive).sample();

        //depending on the values of flags draw alarms
        a[t][0] = bernoulli(flags[t][0]? a1_rf1_TruePositive : a1_rf1_FalsePositive).sample();
        a[t][1] = bernoulli(flags[t][0]? a2_rf1_TruePositive : a2_rf1_FalsePositive).sample();
        a[t][2] = bernoulli(flags[t][1]? a3_rf2_TruePositive : a3_rf2_FalsePositive).sample();

        //depending on the value of alarms, learn flag values and account type

        if (a[t][0]||a[t][1]||a[t][2]){  //if at least one of the alarms goes off
            xDisc[t] = bernoulli(x[t]? 1.0:0.0).sample();
            flagsDisc[t][0] = bernoulli(flags[t][0]?1.0 : 0.0).sample();
            flagsDisc[t][1] = bernoulli(flags[t][1]?1.0 : 0.0).sample();
            }
        }

    xDisc.observe(obsX);
    flagsDisc.observe(obsFlags);
    a.observe(obsA);
}